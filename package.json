{
  "name": "ingles-improve",
  "version": "1.0.0",
  "private": true,
  "description": "Ingles IMPROVE - plataforma full-stack de la escuela de inglés",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "cd client && npm run dev",
    "seed": "node server/seed.js",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x"
  }
}
